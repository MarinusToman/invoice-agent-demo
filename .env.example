# Google (no AI API keys needed — all AI runs locally via Ollama)
SPREADSHEET_ID=your_google_sheet_id_here

# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-level-token-here    # Required for Socket Mode
SLACK_CHANNEL_ID=C000000000                        # Channel where the bot posts

# Email recipients (used when agent sends notifications)
MANAGER_EMAIL=manager@yourbusiness.com
FINANCE_EMAIL=finance@yourbusiness.com

# Agent decision thresholds
AMOUNT_THRESHOLD=5000       # Invoices above this amount trigger an approval request
URGENT_DAYS=7               # Invoices due within this many days trigger a reminder

# Weekly schedule
POLL_WEEKDAY=0              # 0=Monday, 1=Tuesday, ..., 6=Sunday
POLL_HOUR=9                 # Hour to run (24h format, e.g. 9 = 9:00 AM)

# Ollama (set automatically by docker-compose — only change if running outside Docker)
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=qwen2.5-coder:7b
